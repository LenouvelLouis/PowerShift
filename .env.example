# Copy this file to .env and fill in real values

# ── App ──────────────────────────────────────────────────
APP_NAME="Energy Grid API"
APP_VERSION="0.1.0"
DEBUG=false
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development   # development | staging | production

# ── Docker Compose PostgreSQL ─────────────────────────────
POSTGRES_USER=tes_user
POSTGRES_PASSWORD=tes_password
POSTGRES_DB=tes_db

# ── Database ─────────────────────────────────────────────
# Docker Compose (uses 'db' service name):
DATABASE_URL=postgresql+asyncpg://tes_user:tes_password@db:5432/tes_db
# Local dev (outside Docker):
# DATABASE_URL=postgresql+asyncpg://tes_user:tes_password@localhost:5432/tes_db
# NeonDB cloud:
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── Frontend ──────────────────────────────────────────────
# Docker Compose (backend reachable via service name):
NUXT_API_BASE_URL=http://backend:8000
# Local dev:
# NUXT_API_BASE_URL=http://localhost:8000

# ── Azure Key Vault (optional) ───────────────────────────
# Leave blank to skip AKV and rely solely on .env
AZURE_KEY_VAULT_URL=https://your-vault-name.vault.azure.net/
# The two vars below are only needed when running outside Azure with a service principal
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── AKV secret names (if AKV is configured) ──────────────
AKV_SECRET_DATABASE_URL=energy-grid-database-url

# ── KNMI Open Data API ────────────────────────────────────
# Register at https://developer.dataplatform.knmi.nl/ (free)
# Used by scripts/ingest_knmi_wind.py
KNMI_API_KEY=your-knmi-api-key-here
